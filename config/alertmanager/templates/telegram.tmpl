{{ define "telegram.alert" -}}
<b>{{ .Status | toUpper }}</b> | {{ .CommonLabels.severity | upper }}

<b>Host:</b> {{ .CommonLabels.hostname | default "vmi3410257" }}
<b>Service:</b> {{ .CommonLabels.service | default .CommonLabels.job | default "unknown" }}
<b>Alert:</b> {{ .CommonLabels.alertname }}
<b>Summary:</b> {{ .CommonAnnotations.summary | default "No details" }}

{{- if .CommonAnnotations.description }}
<b>Details:</b> {{ .CommonAnnotations.description }}
{{- end }}

<b>Value:</b> {{ .CommonAnnotations.value | default "N/A" }}
<b>Time:</b> {{ .StartsAt.Format "02 Jan 2006 15:04:05 IST" }}
{{- if .DashboardURL }}
<b>Dashboard:</b> {{ .DashboardURL }}
{{- end }}
{{- if .GeneratorURL }}
<b>Source:</b> {{ .GeneratorURL }}
{{- end }}

{{- if .Alerts.Firing }}
<b>Active for:</b> {{ .Alerts.Firing | len }} firing
{{- end }}
{{- end }}
